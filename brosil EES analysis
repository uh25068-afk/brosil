function renderHeatmap(){
  const d=FILTERED;
  // Section heatmap: Division × Section
  let html=`<table class="hm-tbl"><thead><tr><th class="hm-td-label"></th>`;
  SECTIONS.forEach(s=>html+=`<th class="hm-th" title="${s.name}">${s.emoji}</th>`);
  html+=`</tr></thead><tbody>`;
  DIVS.forEach(dv=>{
    const rows=d.filter(r=>r.div===dv);
    html+=`<tr><td class="hm-td-label">${dv}</td>`;
    SECTIONS.forEach(s=>{
      const v=rows.length?secAvg(rows,s):0;
      html+=`<td class="hm-cell" style="background:${hmColor(v)}" title="${dv} · ${s.name}: ${v.toFixed(2)}">${v.toFixed(1)}</td>`;
    });
