  43:"Attempts are made to avoid conflicts at Borosil.",
  44:"There are appropriate systems in place at Borosil to resolve conflicts.",
  45:"Conflicts are resolved timely at Borosil.",
  46:"I believe that the findings of this survey will be acted upon.",
  47:"I am satisfied working for Borosil.",
};

// ════════════════════════════════════════════════════════
// SYNTHETIC DATA (100 respondents × 47 questions)
// Seeded to be realistic — some sections genuinely weaker
// ════════════════════════════════════════════════════════
function seededRand(seed){let s=seed;return function(){s=(s*9301+49297)%233280;return s/233280;}}
const sr=seededRand(42);
function clamp(v){return Math.max(1,Math.min(5,v))}

// Section base scores (some intentionally lower for realistic patterns)
const SEC_BASE={
  company:3.6,leadership:3.4,job:3.7,reward:2.9,communication:3.1,
  teamwork:3.8,training:3.0,physical:3.4,social:2.8,security:3.2,
  goal:3.6,improvement:2.7,compensation:2.5,grievance:2.6,conflict:2.8,
  belief:3.0,overall:3.3
};

const DIVS=["Production","Quality","Maintenance","HR"];
const DIV_MODS={Production:0.1,Quality:0.05,Maintenance:-0.1,HR:0.15};
const LEVELS=["IC","MIC","MM1","MM2","TL"];
const AGES=["18-24","25-34","35-44","45-54","55+"];
const TENURES=["0-1","1-3","3-5","5-8","8-12","12-20","20+"];
const GENDERS=["Male","Female","Others"];

function secForQ(qi){
  for(const s of SECTIONS)if(s.qs.includes(qi))return s;
  return null;
}

const RAW=[];
for(let i=0;i<100;i++){
  const div=DIVS[Math.floor(sr()*DIVS.length)];
  const sub=["A","B","C"][Math.floor(sr()*3)];
  const level=LEVELS[Math.floor(sr()*LEVELS.length)];
  const gender=sr()<0.55?"Male":sr()<0.9?"Female":"Others";
  const age=AGES[Math.floor(sr()*AGES.length)];
  const tenure=TENURES[Math.floor(sr()*TENURES.length)];
  const divMod=DIV_MODS[div]||0;
  const personalBias=(sr()-0.5)*0.6;
  const qs={};
  for(let qi=1;qi<=47;qi++){
    const sec=secForQ(qi);
    const base=SEC_BASE[sec.id]+divMod+personalBias;
    const noise=(sr()-0.5)*1.6;
    qs[qi]=clamp(Math.round(base+noise));
  }
  RAW.push({id:i+1,div,sub,level,gender,age,tenure,...qs});
}

// ════════════════════════════════════════════════════════
// STATE & HELPERS
// ════════════════════════════════════════════════════════
let FILTERED=[...RAW];
let activeDrill=null;

function avg(arr){return arr.length?arr.reduce((a,b)=>a+b,0)/arr.length:0}
function qavg(data,qi){return avg(data.map(r=>r[qi]))}
function secAvg(data,sec){return avg(sec.qs.map(qi=>qavg(data,qi)))}
function secAvgAll(data){return SECTIONS.map(s=>+secAvg(data,s).toFixed(2))}
function rowAvg(row){let s=0;for(let i=1;i<=47;i++)s+=row[i];return s/47;}
function qDist(data,qi){const c=[0,0,0,0,0];data.forEach(r=>c[r[qi]-1]++);return c;}
function hmColor(v){
  if(v>=4.0)return '#16a34a';
  if(v>=3.5)return '#22c55e';
  if(v>=3.0)return '#eab308';
  if(v>=2.5)return '#f97316';
  return '#ef4444';
}
function scoreColorHex(s){return['#ef4444','#f97316','#eab308','#22c55e','#16a34a'][s-1]}
function scoreCls(v){return v<2.7?'score-col':v<3.4?'score-ok':'score-good'}
function scoreLabel(v){return v>=4?'Excellent':v>=3.5?'Good':v>=3?'Neutral':v>=2.5?'Low':'Critical'}
function scoreLabelColor(v){return v>=4?'var(--green)':v>=3.5?'var(--lime)':v>=3?'var(--accent)':v>=2.5?'var(--orange)':'var(--red)'}

// ════════════════════════════════════════════════════════
// FILTERS
// ════════════════════════════════════════════════════════
function applyFilters(){
  const fDiv=document.getElementById('f-div').value;
  const fSub=document.getElementById('f-sub').value;
  const fLevel=document.getElementById('f-level').value;
  const fGender=document.getElementById('f-gender').value;
  const fAge=document.getElementById('f-age').value;
  const fTenure=document.getElementById('f-tenure').value;
  FILTERED=RAW.filter(r=>
    (!fDiv||r.div===fDiv)&&(!fSub||r.sub===fSub)&&(!fLevel||r.level===fLevel)&&
    (!fGender||r.gender===fGender)&&(!fAge||r.age===fAge)&&(!fTenure||r.tenure===fTenure)
  );
  document.getElementById('fc').textContent=FILTERED.length;
  document.getElementById('hdr-count').textContent=FILTERED.length+' Responses';
  renderActive();
}
function resetFilters(){
  ['f-div','f-sub','f-level','f-gender','f-age','f-tenure'].forEach(id=>document.getElementById(id).value='');
  applyFilters();
}

