        pointBackgroundColor:SECTIONS.map(s=>s.color),borderWidth:2,pointRadius:4}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
      scales:{r:{min:1,max:5,ticks:{stepSize:1,color:'var(--text3)',backdropColor:'transparent',font:{size:9}},
        grid:{color:'var(--border2)'},pointLabels:{color:'var(--text2)',font:{size:10}},angleLines:{color:'var(--border2)'}}}}
  });

  // All Q chips
  document.getElementById('ind-all-qs').innerHTML=`<div style="display:flex;flex-wrap:wrap;gap:5px;padding:4px 0">`+
    Array.from({length:47},(_,i)=>{
      const qi=i+1;const sc=r[qi];
      return `<span class="score-chip" style="background:${scoreColorHex(sc)}" title="Q${qi}: ${Q_TEXTS[qi]}">Q${qi}</span>`;
    }).join('')+
    `</div><div style="margin-top:10px;font-size:11px;color:var(--text3)">Hover chips to see question text</div>`;
}

// ════════════════════════════════════════════════════════
// ENGAGEMENT ANALYTICS (Steps 1–15)
// ════════════════════════════════════════════════════════

// Step 1–2: Engagement Score + Category
const ENG_CATS = [
  {id:'superDisengaged', label:'Super Disengaged', min:1.0,  max:1.8,  color:'#7f1d1d', light:'#ef444433'},
  {id:'disengaged',      label:'Disengaged',       min:1.8,  max:2.6,  color:'#ef4444', light:'#ef444433'},
  {id:'neutral',         label:'Neutral',          min:2.6,  max:3.4,  color:'#eab308', light:'#eab30833'},
  {id:'engaged',         label:'Engaged',          min:3.4,  max:4.2,  color:'#22c55e', light:'#22c55e33'},
  {id:'superEngaged',    label:'Super Engaged',    min:4.2,  max:5.01, color:'#16a34a', light:'#16a34a33'},
];

// Step 5: Dimension definitions (4 key + extras for gap analysis)
const DIMENSIONS = [
  {id:'leadership',    label:'Leadership',    emoji:'👔', qs:[4,5,6]},
  {id:'communication', label:'Communication', emoji:'💬', qs:[13,14,15]},
  {id:'compensation',  label:'Compensation',  emoji:'💰', qs:[37,38,39]},
  {id:'training',      label:'Training',      emoji:'📚', qs:[19,20,21]},
  {id:'reward',        label:'Reward & Recog.',emoji:'🏆', qs:[10,11,12]},
  {id:'improvement',   label:'Improvement',   emoji:'🔧', qs:[34,35,36]},
  {id:'grievance',     label:'Grievance',     emoji:'📢', qs:[40,41,42]},
  {id:'social',        label:'Social Env.',   emoji:'🌱', qs:[25,26,27]},
];

function engScore(row){let s=0;for(let i=1;i<=47;i++)s+=row[i];return s/47;}
function engCat(score){
  for(const c of ENG_CATS){if(score>=c.min&&score<c.max)return c;}
  return ENG_CATS[ENG_CATS.length-1];
}
function dimScore(data, dim){
  // avg of q scores across employees
  return avg(data.flatMap(r=>dim.qs.map(qi=>r[qi]).filter(v=>v>=1&&v<=5)));
}
function dimPct(avgScore){return+((avgScore-1)/4*100).toFixed(1);}

function renderEngagement(){
  const d = FILTERED;
  if(!d.length){
    document.getElementById('page-engagement').innerHTML='<div class="card" style="text-align:center;padding:40px;color:var(--text3)">No data matches current filters.</div>';
    return;
  }

  // Step 1–2: Compute scores and categories
  const empScores = d.map(r=>({...r, _score:engScore(r), _cat:engCat(engScore(r))}));
  const catCounts = {};
  ENG_CATS.forEach(c=>catCounts[c.id]=0);
  empScores.forEach(e=>catCounts[e._cat.id]++);

  // Step 3: Engagement %
  const engCount = (catCounts.engaged||0)+(catCounts.superEngaged||0);
  const engPct = d.length ? +(engCount/d.length*100).toFixed(1) : 0;

  // Update ring
  const circ = 2*Math.PI*58;
  const arc = document.getElementById('eng-ring-arc');
  if(arc){
    const offset = circ*(1-engPct/100);
    arc.setAttribute('stroke-dasharray',circ.toFixed(1));
    setTimeout(()=>arc.style.strokeDashoffset=offset.toFixed(1),50);
    const ringColor = engPct>=60?'#22c55e':engPct>=40?'#eab308':'#ef4444';
    arc.setAttribute('stroke',ringColor);
    document.getElementById('eng-ring-arc').setAttribute('stroke',ringColor);
  }
  document.getElementById('eng-pct-num').textContent=engPct+'%';
  document.getElementById('eng-pct-num').style.color=engPct>=60?'var(--green)':engPct>=40?'var(--accent)':'var(--red)';

  // Category chips
  document.getElementById('eng-cat-chips').innerHTML=ENG_CATS.map(c=>`
    <div class="eng-cat-chip" style="background:${c.light};color:${c.color}">
      <div class="eng-cat-dot" style="background:${c.color}"></div>
      ${c.label}: <strong>${catCounts[c.id]}</strong>
    </div>`).join('');

  // Step 4: Distribution bar
  const total = d.length||1;
  document.getElementById('eng-dist-bar').innerHTML=ENG_CATS.map(c=>{
    const w=(catCounts[c.id]/total*100).toFixed(1);
    return`<div class="dist-seg" style="width:${w}%;background:${c.color}" data-tip="${c.label}: ${catCounts[c.id]} (${w}%)">${w>8?catCounts[c.id]:''}</div>`;
  }).join('');
  document.getElementById('eng-dist-legend').innerHTML=ENG_CATS.map(c=>`
    <span style="display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:2px;background:${c.color};display:inline-block"></span>${c.label}: ${catCounts[c.id]}</span>`).join('');

  // Metrics
  const notEngCount=(catCounts.superDisengaged||0)+(catCounts.disengaged||0)+(catCounts.neutral||0);
  const avgEng=avg(empScores.map(e=>e._score));
  document.getElementById('eng-metrics').innerHTML=`
    <div class="metric">
      <div class="metric-val" style="color:${engPct>=60?'var(--green)':engPct>=40?'var(--accent)':'var(--red)'}">${engPct}%</div>
      <div class="metric-label">Engagement %</div>
      <div class="metric-sub">Engaged + Super Engaged</div>
      <div class="metric-bar"><div class="metric-bar-fill" style="width:${engPct}%;background:${engPct>=60?'var(--green)':'var(--accent)'}"></div></div>
    </div>
    <div class="metric">
      <div class="metric-val" style="color:var(--accent)">${avgEng.toFixed(2)}</div>
      <div class="metric-label">Avg Eng. Score</div>
      <div class="metric-sub">Out of 5.00</div>
    </div>
    <div class="metric">
      <div class="metric-val" style="color:var(--red)">${notEngCount}</div>
      <div class="metric-label">Not Engaged</div>
      <div class="metric-sub">Requires attention</div>
    </div>
    <div class="metric">
      <div class="metric-val" style="color:var(--green)">${engCount}</div>
      <div class="metric-label">Engaged Employees</div>
      <div class="metric-sub">Engaged + Super Engaged</div>
    </div>`;

  // Step 4: Distribution bar chart
  mkChart('eng-dist-chart',{
    type:'bar',
    data:{
      labels:ENG_CATS.map(c=>c.label),
      datasets:[{
        data:ENG_CATS.map(c=>catCounts[c.id]),
        backgroundColor:ENG_CATS.map(c=>c.color+'cc'),
        borderColor:ENG_CATS.map(c=>c.color),
        borderWidth:1,borderRadius:8,borderSkipped:false
      }]
    },
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>`${ctx.raw} employees (${(ctx.raw/total*100).toFixed(1)}%)`}}},
      scales:{y:{beginAtZero:true,grid:{color:'var(--surface3)'},ticks:{color:'var(--text2)',font:{size:11}}},
              x:{grid:{display:false},ticks:{color:'var(--text2)',font:{size:10}}}}}
  });

  // Step 5: Dimension scores (overall)
  const dimScores = DIMENSIONS.map(dim=>({...dim, avgScore:dimScore(d,dim), pct:dimPct(dimScore(d,dim))}));
  const maxPct = Math.max(...dimScores.map(x=>x.pct),1);
  document.getElementById('eng-dim-bars').innerHTML=dimScores.map(dim=>{
    const col=dim.pct>=65?'var(--green)':dim.pct>=50?'var(--accent)':'var(--red)';
    return`<div class="dim-bar-row">
      <div class="dim-icon">${dim.emoji}</div>
      <div class="dim-name">${dim.label}</div>
      <div class="dim-track"><div class="dim-fill" style="width:${dim.pct}%;background:${col}"></div></div>
      <div class="dim-pct" style="color:${col}">${dim.pct}%</div>
    </div>`;
  }).join('');

  // Step 7: Not Engaged group
  const notEngGroup = empScores.filter(e=>['superDisengaged','disengaged','neutral'].includes(e._cat.id));
  document.getElementById('not-eng-count').textContent=notEngGroup.length;

  // Step 8–9: Dim scores for not engaged
  const notEngDimScores = DIMENSIONS.map(dim=>({...dim, avgScore:dimScore(notEngGroup,dim), pct:dimPct(dimScore(notEngGroup,dim))}));
  const bottom3 = [...notEngDimScores].sort((a,b)=>a.pct-b.pct).slice(0,3).map(x=>x.id);

  document.getElementById('noteng-dim-bars').innerHTML=notEngDimScores.map(dim=>{
    const isBottom=bottom3.includes(dim.id);
    const col=isBottom?'var(--red)':dim.pct>=50?'var(--accent)':'var(--orange)';
    return`<div class="dim-bar-row" style="${isBottom?'background:var(--red-dim);border-radius:var(--r-xs);padding:6px 8px;':''}">
      <div class="dim-icon">${dim.emoji}</div>
      <div class="dim-name">${dim.label}</div>
      <div class="dim-track"><div class="dim-fill" style="width:${dim.pct}%;background:${col}"></div></div>
      <div class="dim-pct" style="color:${col}">${dim.pct}%</div>
      ${isBottom?'<div class="dim-flag" style="background:var(--red-dim);color:var(--red)">⚠️ Low</div>':''}
    </div>`;
  }).join('');

  // Step 10–11: Gap chart
  const gapData = DIMENSIONS.map(dim=>{
    const overall=dimPct(dimScore(d,dim));
    const notEng=notEngGroup.length?dimPct(dimScore(notEngGroup,dim)):0;
    return{...dim,overall,notEng,gap:+(overall-notEng).toFixed(1)};
  });

  mkChart('gap-chart',{
    type:'bar',
    data:{
      labels:gapData.map(d=>`${d.emoji} ${d.label}`),
      datasets:[
        {label:'Overall',data:gapData.map(x=>x.overall),backgroundColor:'#3b82f6aa',borderColor:'#3b82f6',borderWidth:1,borderRadius:4},
        {label:'Not Engaged',data:gapData.map(x=>x.notEng),backgroundColor:gapData.map(x=>bottom3.includes(x.id)?'#ef4444cc':'#f97316aa'),borderColor:gapData.map(x=>bottom3.includes(x.id)?'#ef4444':'#f97316'),borderWidth:1,borderRadius:4}
      ]
    },
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{position:'top',labels:{color:'var(--text2)',font:{size:11},padding:12}},
        tooltip:{callbacks:{label:ctx=>`${ctx.dataset.label}: ${ctx.raw}%`}}},
      scales:{y:{beginAtZero:true,max:100,ticks:{callback:v=>v+'%',color:'var(--text2)',font:{size:10}},grid:{color:'var(--surface3)'}},
              x:{grid:{display:false},ticks:{color:'var(--text2)',font:{size:10},maxRotation:30}}}}
  });

  // Gap table
  document.getElementById('gap-table-body').innerHTML=gapData.map(x=>{
    const isBot=bottom3.includes(x.id);
    const gapCol=x.gap>20?'var(--red)':x.gap>10?'var(--orange)':'var(--text2)';
    return`<tr style="${isBot?'background:var(--red-dim);':''}">
      <td style="font-weight:600;color:var(--text)">${x.emoji} ${x.label} ${isBot?'<span style="font-size:10px;color:var(--red)">⚠️ Bottom 3</span>':''}</td>
      <td style="text-align:center;color:var(--green);font-weight:700">${x.overall}%</td>
      <td style="text-align:center;color:${isBot?'var(--red)':'var(--orange)'};font-weight:700">${x.notEng}%</td>
      <td style="text-align:center"><span style="background:${x.gap>20?'var(--red-dim)':x.gap>10?'#f9731622':'var(--surface3)'};color:${gapCol};padding:2px 8px;border-radius:10px;font-weight:700">−${x.gap}%</span></td>
      <td><span class="cat-pill" style="background:${isBot?'var(--red-dim)':'var(--surface3)'};color:${isBot?'var(--red)':'var(--text2)'}">${isBot?'🔴 Key Driver':'–'}</span></td>
    </tr>`;
  }).join('');

  // Step 12: Auto-generated insights
  const bottom3Dims = [...gapData].sort((a,b)=>a.notEng-b.notEng).slice(0,3);
  const insightTexts = {
    leadership:  (g)=>`Leadership scores among disengaged employees are ${g}% lower — lack of motivation from superiors and perceived unfairness are likely contributing to disengagement.`,
    communication:(g)=>`Communication gaps of ${g}% in the not-engaged group suggest that feedback channels and information flow are major pain points driving dissatisfaction.`,
    compensation:(g)=>`Compensation scores drop ${g}% among disengaged employees — perceived inequity in pay and incentives is a significant dissatisfaction driver.`,
    training:    (g)=>`Training scores are ${g}% lower among disengaged employees — limited development opportunities and skill-building gaps are fuelling disengagement.`,
    reward:      (g)=>`Reward & Recognition is ${g}% lower among disengaged employees — employees feel their good work goes unnoticed or is not fairly rewarded.`,
    improvement: (g)=>`Improvement Orientation gap of ${g}% indicates disengaged employees feel suggestions are not welcomed or implemented, reducing their sense of ownership.`,
    grievance:   (g)=>`Grievance Redressal is ${g}% lower in the not-engaged group — unaddressed concerns are likely amplifying frustration and disengagement.`,
    social:      (g)=>`Social Environment scores drop ${g}% among disengaged employees — poor work-life integration and inadequate external facilities are affecting morale.`,
  };
  const dimColors=['#ef4444','#f97316','#eab308'];
  document.getElementById('eng-insights').innerHTML=bottom3Dims.map((dim,i)=>`
    <div class="insight-card">
      <div class="insight-num" style="background:${dimColors[i]}">${i+1}</div>
      <div class="insight-body">
        <div class="insight-title">${dim.emoji} ${dim.label}</div>
        <div class="insight-text">${(insightTexts[dim.id]||((g)=>`${dim.label} is ${g}% lower among disengaged employees — a key driver of dissatisfaction.`))(dim.gap)}</div>
        <span class="insight-gap" style="background:var(--red-dim);color:var(--red)">Gap: −${dim.gap}% vs overall</span>
        <span class="insight-gap" style="background:var(--surface3);color:var(--text2);margin-left:6px">Overall: ${dim.overall}% · Not Engaged: ${dim.notEng}%</span>
      </div>
    </div>`).join('');

  // Step 13: High-risk groups
  function disengagePct(group){
    if(!group.length)return 0;
    const notEng=group.filter(e=>['superDisengaged','disengaged','neutral'].includes(e._cat.id));
    return+(notEng.length/group.length*100).toFixed(1);
  }
  // By division
  const divRisk=DIVS.map(dv=>({label:dv,pct:disengagePct(empScores.filter(e=>e.div===dv))})).sort((a,b)=>b.pct-a.pct);
  // By level
  const LEVELS2=['IC','MIC','MM1','MM2','TL'];
  const levelRisk=LEVELS2.map(lv=>({label:lv,pct:disengagePct(empScores.filter(e=>e.level===lv))})).sort((a,b)=>b.pct-a.pct);
  // By tenure
  const TENURES2=['0-1','1-3','3-5','5-8','8-12','12-20','20+'];
  const tenureRisk=TENURES2.map(t=>({label:t+' yrs',pct:disengagePct(empScores.filter(e=>e.tenure===t))})).sort((a,b)=>b.pct-a.pct);

  const topDiv=divRisk[0], topLevel=levelRisk[0], topTenure=tenureRisk[0];
  document.getElementById('risk-groups').innerHTML=`
    <div style="margin-bottom:14px;padding:10px 14px;background:var(--red-dim);border-radius:var(--r-xs);font-size:12px;color:#fca5a5;border:1px solid #ef444433">
      <strong>⚠️ Highest disengagement observed in:</strong><br>
      Division: <strong>${topDiv?.label}</strong> (${topDiv?.pct}%) · Level: <strong>${topLevel?.label}</strong> (${topLevel?.pct}%) · Tenure: <strong>${topTenure?.label}</strong> (${topTenure?.pct}%)
    </div>
    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text3);margin-bottom:8px">By Division</div>
    ${divRisk.map(r=>`<div class="risk-row">
      <div class="risk-label">${r.label}</div>
      <div style="flex:1;height:6px;background:var(--surface3);border-radius:3px;overflow:hidden">
        <div style="width:${r.pct}%;height:100%;background:${r.pct>60?'var(--red)':r.pct>40?'var(--orange)':'var(--accent)'};border-radius:3px"></div>
      </div>
      <div class="risk-pct" style="background:${r.pct>60?'var(--red-dim)':r.pct>40?'var(--orange-dim)':'var(--surface3)'};color:${r.pct>60?'var(--red)':r.pct>40?'var(--orange)':'var(--text2)'}">${r.pct}%</div>
    </div>`).join('')}
    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text3);margin:12px 0 8px">By Responsibility Level</div>
    ${levelRisk.map(r=>`<div class="risk-row">
      <div class="risk-label">${r.label}</div>
      <div style="flex:1;height:6px;background:var(--surface3);border-radius:3px;overflow:hidden">
        <div style="width:${r.pct}%;height:100%;background:${r.pct>60?'var(--red)':'var(--purple)'};border-radius:3px"></div>
      </div>
      <div class="risk-pct" style="background:var(--purple-dim);color:var(--purple)">${r.pct}%</div>
    </div>`).join('')}`;

  // Risk chart — disengagement by tenure
  mkChart('risk-chart',{
    type:'bar',
    data:{
      labels:tenureRisk.map(r=>r.label),
      datasets:[{
        label:'Not Engaged %',
        data:tenureRisk.map(r=>r.pct),
        backgroundColor:tenureRisk.map(r=>r.pct>60?'#ef4444cc':r.pct>40?'#f97316cc':'#eab308cc'),
        borderColor:tenureRisk.map(r=>r.pct>60?'#ef4444':r.pct>40?'#f97316':'#eab308'),
        borderWidth:1,borderRadius:7,borderSkipped:false
      }]
    },
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>`Not Engaged: ${ctx.raw}%`}}},
      scales:{y:{beginAtZero:true,max:100,ticks:{callback:v=>v+'%',color:'var(--text2)',font:{size:10}},grid:{color:'var(--surface3)'}},
              x:{grid:{display:false},ticks:{color:'var(--text2)',font:{size:10}}}}}
  });

  // Employee table
  document.getElementById('eng-emp-table').innerHTML=empScores.slice(0,150).map(e=>{
    const c=e._cat;
    return`<tr>
      <td style="color:var(--text3)">${e.id}</td>
      <td>${e.div}</td><td>${e.level}</td><td>${e.gender}</td><td>${e.tenure}</td>
      <td style="text-align:center;font-weight:700;color:${c.color}">${e._score.toFixed(2)}</td>
      <td style="text-align:center"><span class="cat-pill" style="background:${c.light};color:${c.color}">${c.label}</span></td>
    </tr>`;
  }).join('');
}

// ════════════════════════════════════════════════════════
// PAGE NAV — updated to include engagement
// ════════════════════════════════════════════════════════
let activePage='sections';
function showPage(name, btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  if(btn)btn.classList.add('active');
  else{
    document.querySelectorAll('.nav-btn').forEach(b=>{
      if(b.getAttribute('onclick')&&b.getAttribute('onclick').includes("'"+name+"'"))b.classList.add('active');
    });
  }
  activePage=name;
  renderActive();
}
function renderActive(){
  if(activePage==='sections')renderSections();
  else if(activePage==='engagement')renderEngagement();
  else if(activePage==='overview')renderOverview();
  else if(activePage==='compare')renderCompare();
  else if(activePage==='heatmap')renderHeatmap();
  else if(activePage==='problems')renderProblems();
  else if(activePage==='individual')renderIndividual();
}

// ════════════════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════════════════
initIndividualSelect();
renderSections();
</script>
