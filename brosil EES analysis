// PAGE: PROBLEMS
// ════════════════════════════════════════════════════════
function renderProblems(){
  const d=FILTERED;
  // Section alerts
  const secSorted=[...SECTIONS].map(s=>({...s,avg:secAvg(d,s)})).sort((a,b)=>a.avg-b.avg);
  const critSecs=secSorted.filter(s=>s.avg<3);
  let alertsHtml='';
  critSecs.forEach(s=>{
    alertsHtml+=`<div class="hl hl-red">⚠️ <strong>${s.emoji} ${s.name}</strong> — Avg ${s.avg.toFixed(2)}/5.00 — Below 3.0 threshold, requires immediate attention</div>`;
  });
  secSorted.filter(s=>s.avg>=3&&s.avg<3.4).forEach(s=>{
    alertsHtml+=`<div class="hl hl-amber">○ <strong>${s.emoji} ${s.name}</strong> — Avg ${s.avg.toFixed(2)}/5.00 — Moderate concern</div>`;
  });
  if(critSecs.length===0)alertsHtml=`<div class="hl hl-green">✓ No sections below 3.0 — all areas showing acceptable scores</div>`;
  document.getElementById('prob-alerts').innerHTML=alertsHtml;

  // Bottom 5 questions
  const qall=[];
  for(let qi=1;qi<=47;qi++){
    const sec=secForQ(qi);
    qall.push({qi,avg:+qavg(d,qi).toFixed(2),sec});
  }
  const sorted=[...qall].sort((a,b)=>a.avg-b.avg);
  document.getElementById('prob-bottom').innerHTML=sorted.slice(0,5).map(x=>`
    <div class="stat-row">
      <div class="stat-name">Q${x.qi} (${x.sec.name.substring(0,10)})</div>
      <div class="stat-bar-wrap"><div class="stat-bar" style="width:${x.avg/5*100}%;background:var(--red)"></div></div>
      <div class="stat-val" style="color:var(--red)">${x.avg}</div>
    </div>`).join('');
  document.getElementById('prob-top').innerHTML=[...sorted].reverse().slice(0,5).map(x=>`
    <div class="stat-row">
      <div class="stat-name">Q${x.qi} (${x.sec.name.substring(0,10)})</div>
      <div class="stat-bar-wrap"><div class="stat-bar" style="width:${x.avg/5*100}%;background:var(--green)"></div></div>
      <div class="stat-val" style="color:var(--green)">${x.avg}</div>
    </div>`).join('');

  // Worst sections per division
  let wstHtml='';
  DIVS.forEach((dv,i)=>{
    const rows=d.filter(r=>r.div===dv);
    if(!rows.length)return;
    const worst=SECTIONS.map(s=>({s,v:secAvg(rows,s)})).sort((a,b)=>a.v-b.v)[0];
    const colors=['#3b82f6','#10b981','#f97316','#a855f7'];
    wstHtml+=`<div class="stat-row">
      <div class="stat-name" style="color:${colors[i]};font-weight:700">${dv}</div>
      <div style="flex:1;font-size:12px;color:var(--text2)">${worst.s.emoji} ${worst.s.name}</div>
      <div class="stat-val" style="color:var(--red)">${worst.v.toFixed(2)}</div>
    </div>`;
  });
  document.getElementById('prob-worst-sections').innerHTML=wstHtml;

  // Dissatisfaction (score=1) by section
  const dis1=SECTIONS.map(s=>{
    let cnt=0,tot=0;
    s.qs.forEach(qi=>{d.forEach(r=>{tot++;if(r[qi]===1)cnt++;});});
    return+(cnt/tot*100).toFixed(1);
  });
  mkChart('chart-dis-rate',{
    type:'bar',
    data:{labels:SECTIONS.map(s=>s.emoji),datasets:[{data:dis1,backgroundColor:SECTIONS.map(s=>s.color+'99'),borderColor:SECTIONS.map(s=>s.color),borderWidth:1,borderRadius:5}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:(ctx)=>`${dis1[ctx.dataIndex]}% dissatisfied`}}},scales:{y:{beginAtZero:true,ticks:{callback:v=>v+'%',color:'var(--text2)'},grid:{color:'var(--surface3)'}},x:{grid:{display:false},ticks:{color:'var(--text)'}}}}
  });
}

