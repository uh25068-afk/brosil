<script>
// ════════════════════════════════════════════════════════
// SECTION DEFINITIONS  (from Borosil PDF)
// ════════════════════════════════════════════════════════
const SECTIONS = [
  {id:'company',      name:'Company',                 emoji:'🏢', qs:[1,2,3],    color:'#3b82f6'},
  {id:'leadership',   name:'Leadership',              emoji:'👔', qs:[4,5,6],    color:'#a855f7'},
  {id:'job',          name:'Job',                     emoji:'💼', qs:[7,8,9],    color:'#06b6d4'},
  {id:'reward',       name:'Reward & Recognition',    emoji:'🏆', qs:[10,11,12], color:'#f59e0b'},
  {id:'communication',name:'Communication',           emoji:'💬', qs:[13,14,15], color:'#ec4899'},
  {id:'teamwork',     name:'Teamwork',                emoji:'🤝', qs:[16,17,18], color:'#10b981'},
  {id:'training',     name:'Training & Development',  emoji:'📚', qs:[19,20,21], color:'#f97316'},
  {id:'physical',     name:'Physical Environment',    emoji:'🏭', qs:[22,23,24], color:'#84cc16'},
  {id:'social',       name:'Social Environment',      emoji:'🌱', qs:[25,26,27], color:'#22d3ee'},
  {id:'security',     name:'Job Security',            emoji:'🔒', qs:[28,29,30], color:'#8b5cf6'},
  {id:'goal',         name:'Goal Alignment',          emoji:'🎯', qs:[31,32,33], color:'#6366f1'},
  {id:'improvement',  name:'Improvement Orientation', emoji:'🔧', qs:[34,35,36], color:'#f43f5e'},
  {id:'compensation', name:'Compensation',            emoji:'💰', qs:[37,38,39], color:'#d97706'},
  {id:'grievance',    name:'Grievance Redressal',     emoji:'📢', qs:[40,41,42], color:'#059669'},
  {id:'conflict',     name:'Conflict Resolution',     emoji:'⚖️', qs:[43,44,45], color:'#ef4444'},
  {id:'belief',       name:'Belief in Action',        emoji:'🌟', qs:[46],       color:'#fbbf24'},
  {id:'overall',      name:'Overall Satisfaction',    emoji:'😊', qs:[47],       color:'#4ade80'},
];

const Q_TEXTS = {
  1:"I like the work culture at Borosil.",
  2:"I believe that my company cares for its employees.",
  3:"I am proud to be an employee of Borosil.",
  4:"My superiors play a vital role in my motivation.",
  5:"I enjoy a good relationship with my superiors.",
  6:"My superiors are fair and impartial.",
  7:"I like my role and responsibilities.",
  8:"I am given sufficient freedom to do my job.",
  9:"I am given the right tools and equipments to do my job.",
  10:"Good work is duly recognized at Borosil.",
  11:"Borosil equally rewards good work.",
  12:"The reward and recognition process at Borosil is fair and transparent.",
  13:"Communication framework at Borosil is effective and time efficient.",
  14:"I receive timely and proper feedback about my work.",
  15:"I am satisfied with the communication forums available to employees at Borosil.",
  16:"I share good relation with my co-workers.",
  17:"My co-workers and I work together to solve problems at work.",
  18:"I am satisfied with the level of cooperation between my department and other departments.",
  19:"I receive necessary training to do my job well.",
  20:"I get opportunities to visit other plants to learn best practices.",
  21:"Working at Borosil helps me develop as a professional.",
  22:"I am satisfied with the quality of amenities provided at my workplace.",
  23:"I feel safe at my workplace.",
  24:"The environment at my workplace is conducive to my productivity.",
  25:"Borosil takes care of my life outside my workplace.",
  26:"I am satisfied with the quality of facilities extended to me outside my workplace.",
