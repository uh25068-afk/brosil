function renderSections(){
  const d=FILTERED;
  // Summary metrics
  const overallAvg=avg(d.map(rowAvg));
  const secAvgs=SECTIONS.map(s=>secAvg(d,s));
  const worstSec=SECTIONS[secAvgs.indexOf(Math.min(...secAvgs))];
  const bestSec=SECTIONS[secAvgs.indexOf(Math.max(...secAvgs))];
  const critCount=secAvgs.filter(v=>v<3).length;

  document.getElementById('sec-summary-metrics').innerHTML=`
    <div class="metric">
      <div class="metric-val" style="color:var(--accent)">${overallAvg.toFixed(2)}</div>
      <div class="metric-label">Overall Avg</div>
      <div class="metric-sub">Across all 47 questions</div>
      <div class="metric-bar"><div class="metric-bar-fill" style="width:${overallAvg/5*100}%;background:var(--accent)"></div></div>
    </div>
    <div class="metric">
      <div class="metric-val" style="color:var(--red)">${critCount}</div>
      <div class="metric-label">Sections Below 3.0</div>
      <div class="metric-sub">Need urgent attention</div>
    </div>
    <div class="metric">
      <div class="metric-val" style="color:var(--red);font-size:20px;padding-top:4px">${worstSec.emoji} ${worstSec.name}</div>
      <div class="metric-label">Lowest Section</div>
      <div class="metric-sub">${secAvg(d,worstSec).toFixed(2)} / 5.00</div>
    </div>
    <div class="metric">
      <div class="metric-val" style="color:var(--green);font-size:20px;padding-top:4px">${bestSec.emoji} ${bestSec.name}</div>
      <div class="metric-label">Highest Section</div>
      <div class="metric-sub">${secAvg(d,bestSec).toFixed(2)} / 5.00</div>
    </div>`;

  // Section cards
  const cardsHtml=SECTIONS.map(sec=>{
    const sv=secAvg(d,sec);
    const cls=scoreCls(sv);
    const label=scoreLabel(sv);
    const labelColor=scoreLabelColor(sv);
    const qChips=sec.qs.map(qi=>{
      const qv=qavg(d,qi);
      return `<span class="sec-q-chip" style="background:${hmColor(qv)}33;color:${hmColor(qv)}" title="Q${qi}: ${qv.toFixed(2)}"  onclick="event.stopPropagation();drillToQ(${qi})">Q${qi}: ${qv.toFixed(2)}</span>`;
    }).join('');
    const alertMsg=sv<3?`<div class="sec-alert">⚠️ Needs attention</div>`:
                   sv<3.5?`<div class="sec-alert" style="color:var(--accent)">○ Moderate</div>`:
                   `<div class="sec-alert" style="color:var(--green)">✓ On track</div>`;
    return `<div class="sec-card ${cls}" style="--c:${sec.color}" onclick="toggleDrill('${sec.id}')">
      <div class="sec-header">
        <div>
          <div style="font-size:22px;margin-bottom:4px">${sec.emoji}</div>
          <div class="sec-name">${sec.name}</div>
        </div>
        <div>
          <div class="sec-score" style="color:${sec.color}">${sv.toFixed(2)}</div>
          <div style="font-size:9px;text-align:right;color:var(--text3)">/ 5.00</div>
        </div>
      </div>
      <div class="sec-badge" style="background:${labelColor}22;color:${labelColor}">${label}</div>
      <div class="sec-progress"><div class="sec-prog-fill" style="width:${sv/5*100}%;background:${sec.color}"></div></div>
      <div class="sec-qs">${qChips}</div>
      ${alertMsg}
    </div>`;
  }).join('');
  document.getElementById('section-cards').innerHTML=cardsHtml;

  // Radar chart
  const radarData=SECTIONS.map(s=>+secAvg(d,s).toFixed(2));
  mkChart('radar-chart',{
    type:'radar',
    data:{
      labels:SECTIONS.map(s=>s.emoji+' '+s.name),
      datasets:[{
        label:'Avg Score',data:radarData,
        borderColor:SECTIONS.map(s=>s.color),
        backgroundColor:'rgba(245,158,11,0.08)',
        borderWidth:2,pointBackgroundColor:SECTIONS.map(s=>s.color),
        pointRadius:5,fill:true
      }]
    },
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{r:{min:1,max:5,ticks:{stepSize:1,color:'var(--text3)',font:{size:9},backdropColor:'transparent'},
        grid:{color:'var(--border2)'},pointLabels:{color:'var(--text2)',font:{size:11}},angleLines:{color:'var(--border2)'}}}}
  });
}

function toggleDrill(secId){
  const panel=document.getElementById('drill-panel');
  if(activeDrill===secId){activeDrill=null;panel.classList.remove('open');return;}
  activeDrill=secId;
  panel.classList.add('open');
  renderDrill(secId);
  // scroll
  setTimeout(()=>panel.scrollIntoView({behavior:'smooth',block:'nearest'}),50);
}

function renderDrill(secId){
  const sec=SECTIONS.find(s=>s.id===secId);
  const d=FILTERED;
  const sv=secAvg(d,sec).toFixed(2);
  let html=`<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap">
    <span style="font-size:28px">${sec.emoji}</span>
    <div>
      <div style="font-family:'Playfair Display',serif;font-size:20px;font-weight:600;color:var(--text)">${sec.name}</div>
      <div style="font-size:12px;color:var(--text2)">Section average: <strong style="color:${sec.color}">${sv} / 5.00</strong></div>
    </div>
    <button onclick="toggleDrill('${secId}')" style="margin-left:auto;background:var(--surface3);border:1px solid var(--border2);color:var(--text2);border-radius:var(--r-xs);padding:6px 12px;cursor:pointer;font-size:12px;font-family:inherit">✕ Close</button>
  </div>`;

  // Q-by-Q rows
  html+=`<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--r-sm);overflow:hidden;margin-bottom:14px">`;
  sec.qs.forEach(qi=>{
    const qv=qavg(d,qi).toFixed(2);
    const dist=qDist(d,qi);
    const total=dist.reduce((a,b)=>a+b,0)||1;
    const segs=dist.map((c,i)=>`<div class="q-d-seg" style="width:${c/total*100}%;background:${scoreColorHex(i+1)}" title="Score ${i+1}: ${c}"></div>`).join('');
    html+=`<div class="q-row">
      <div class="q-num" style="background:${sec.color}">${qi}</div>
      <div class="q-text">${Q_TEXTS[qi]}</div>
      <div class="q-dist">${segs}</div>
      <div class="q-avg" style="color:${scoreLabelColor(+qv)}">${qv}</div>
    </div>`;
  });
  html+='</div>';

  // Mini bar chart comparing divisions
  html+=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
    <div>
      <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text3);margin-bottom:10px">Score by Division</div>`;
  DIVS.forEach((dv,i)=>{
    const dvRows=d.filter(r=>r.div===dv);
    const dvSec=dvRows.length?secAvg(dvRows,sec):0;
    const colors=['#3b82f6','#10b981','#f97316','#a855f7'];
    html+=`<div class="cmp-row">
      <div class="cmp-label">${dv}</div>
      <div class="cmp-track"><div class="cmp-fill" style="width:${dvSec/5*100}%;background:${colors[i]}">${dvSec.toFixed(2)}</div></div>
    </div>`;
  });
  html+=`</div><div>
    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--text3);margin-bottom:10px">Score by Level</div>`;
  LEVELS.forEach(lv=>{
    const lvRows=d.filter(r=>r.level===lv);
    const lvSec=lvRows.length?secAvg(lvRows,sec):0;
    html+=`<div class="cmp-row">
      <div class="cmp-label">${lv}</div>
      <div class="cmp-track"><div class="cmp-fill" style="width:${lvSec/5*100}%;background:${sec.color}">${lvSec.toFixed(2)}</div></div>
    </div>`;
  });
  html+=`</div></div>`;

  document.getElementById('drill-content').innerHTML=html;
}

function drillToQ(qi){
  const sec=secForQ(qi);
  if(sec){showPage('sections');toggleDrill(sec.id);}
}

